<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter>
    <!--
        JPA model entities use shared object references by design.
        Defensive copies would break Hibernate's identity model.
    -->
    <Match>
        <Package name="us.calubrecht.lazerwiki.model"/>
        <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2"/>
    </Match>

    <!--
        Response DTOs are serialized to JSON immediately after creation.
        Request DTOs are deserialized by Jackson and not retained by callers.
        Defensive copies in these short-lived objects provide no real benefit.
    -->
    <Match>
        <Package name="us.calubrecht.lazerwiki.responses"/>
        <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2"/>
    </Match>
    <Match>
        <Package name="us.calubrecht.lazerwiki.requests"/>
        <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2"/>
    </Match>

    <!--
        Spring-injected service dependencies are stored by constructor injection —
        the container owns the lifecycle, so storing the reference is not an exposure.
    -->
    <Match>
        <Class name="~us\.calubrecht\.lazerwiki\.service\..*"/>
        <Bug pattern="EI_EXPOSE_REP2"/>
    </Match>

    <!--
        renderState is intentionally shared and mutable — renderers write into it
        to pass state between components during page rendering.
    -->
    <Match>
        <Class name="us.calubrecht.lazerwiki.service.renderhelpers.RenderContext"/>
        <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2"/>
    </Match>

    <!--
        Syntax framework parse tree nodes and parsers use shared object references
        by design — the tree is built and traversed within a single render cycle.
    -->
    <Match>
        <Class name="~us\.calubrecht\.lazerwiki\.syntax\..*"/>
        <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2"/>
    </Match>

    <!--
        Inner class RenderOutputImpl exposes render state intentionally —
        callers read it to extract macro output after rendering.
    -->
    <Match>
        <Class name="us.calubrecht.lazerwiki.service.MacroService$RenderOutputImpl"/>
        <Bug pattern="EI_EXPOSE_REP"/>
    </Match>

    <!--
        Inner class LogoutListener stores this$0 (implicit outer class reference) —
        unavoidable Java inner class behavior, not a real exposure.
    -->
    <Match>
        <Class name="us.calubrecht.lazerwiki.LazerWikiApplication$LogoutListener"/>
        <Bug pattern="EI_EXPOSE_REP2"/>
    </Match>

    <!--
        \n is the correct line separator for HTTP-served HTML output.
        %n produces platform-specific separators (\r\n on Windows), which is wrong here.
    -->
    <Match>
        <Bug pattern="VA_FORMAT_STRING_USES_NEWLINE"/>
    </Match>

    <!--
        PageLockKey is a JPA @IdClass — its fields are populated by Hibernate via
        reflection and are invisible to SpotBugs static analysis.
    -->
    <Match>
        <Class name="us.calubrecht.lazerwiki.model.PageLockKey"/>
        <Bug pattern="UUF_UNUSED_PUBLIC_OR_PROTECTED_FIELD"/>
    </Match>
</FindBugsFilter>
